    "/api/v1/registration-applications/{id}/submit": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "company-name": "Acme Registry Ltd",
                "proposed-directors": [
                  {
                    "id": "director-1",
                    "identity-verified": true,
                    "name": "Jane Smith",
                    "natural-person": true
                  },
                  {
                    "id": "director-2",
                    "identity-verified": true,
                    "name": "Alice Jones",
                    "natural-person": true
                  }
                ],
                "registered-office-address": {
                  "address-line-1": "1 Main Street",
                  "city": "Dublin",
                  "country": "IE"
                }
              },
              "schema": {
                "properties": {
                  "company-name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "proposed-directors": {
                    "items": {
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "identity-verified": {
                          "type": "boolean"
                        },
                        "name": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "natural-person": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "id",
                        "name",
                        "natural-person",
                        "identity-verified"
                      ],
                      "type": "object"
                    },
                    "minItems": 2,
                    "type": "array"
                  },
                  "registered-office-address": {
                    "properties": {
                      "address-line-1": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "city": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "country": {
                        "minLength": 1,
                        "type": "string"
                      }
                    },
                    "required": [
                      "address-line-1",
                      "city",
                      "country"
                    ],
                    "type": "object"
                  }
                },
                "required": [
                  "company-name",
                  "proposed-directors",
                  "registered-office-address"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
