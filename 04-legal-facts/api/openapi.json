    "/api/v1/register": {
      "get": {
        "parameters": [
          {
            "description": "Company name fragment",
            "in": "query",
            "name": "name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "companies": {
                      "items": {
                        "properties": {
                          "company-name": {
                            "type": "string"
                          },
                          "registered-at": {
                            "format": "date-time",
                            "type": "string"
                          },
                          "registration-number": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "registration-number",
                          "company-name",
                          "registered-at"
                        ],
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "companies"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Matching registered companies"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Missing bearer token"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Search the register by company name",
        "tags": [
          "register"
        ]
      }
    },
