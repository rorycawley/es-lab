{:paths ["."]
 :tasks
 {:requires ([babashka.process :refer [shell]]
             [clojure.string :as str]
             [clojure.test :as t])

  :init (do
          (defn sh [& args]
            (binding [*out* *err*]
              (apply println "+" (remove map? args)))
            (apply shell args))

          (defn assert-no-running-containers! []
            (let [result (shell {:out :string}
                                "docker" "compose" "ps" "--services" "--filter" "status=running")]
              (when-not (str/blank? (:out result))
                (throw (ex-info "docker compose still has running containers"
                                {:containers (:out result)}))))))

  help
  {:doc              "Show setup prerequisites and available tasks"
   :override-builtin true
   :task             (do (println "")
                         (println "Prerequisites:")
                         (println "  1. Install mise: curl https://mise.run | sh")
                         (println "  2. Run: mise install   (installs bb and node; only needed once to bootstrap)")
                         (println "")
                         (println "Then:")
                         (println "  bb all    (trust config + install tools + install browsers + run all tests)")
                         (println "  bb tasks  (list all available tasks)")
                         (println "")
                         (println "After bb up, the stack is available at:")
                         (println "  http://localhost:4200              Angular app")
                         (println "  http://localhost:8080/health       backend health endpoint")
                         (println "  http://localhost:8080/openapi.json backend OpenAPI spec")
                         (println "  http://localhost:8080/swagger-ui   backend API browser")
                         (println "")
                         (println "Rancher Desktop users — one-time machine setup for bb test:backend:")
                         (println "  Adapter tests use Testcontainers. Rancher Desktop places the Docker socket at")
                         (println "  ~/.rd/docker.sock and requires API version >=1.41, but docker-java defaults to")
                         (println "  1.32. Fix with two properties files (create if missing):")
                         (println "")
                         (println "  ~/.docker-java.properties")
                         (println "    api.version=1.44")
                         (println "")
                         (println "  ~/.testcontainers.properties")
                         (println "    docker.host=unix:///Users/$USER/.rd/docker.sock")
                         (println "    ryuk.disabled=true")
                         (println "    checks.disable=true")
                         (println "")
                         (println "  Also ensure Rancher Desktop is using dockerd (moby), not containerd.")
                         (println ""))}

  setup
  {:doc  "Trust mise.toml, install tools, install npm packages, and install Playwright browsers"
   :task (do (sh "mise" "trust")
             (sh "mise" "install")
             (sh {:dir "frontend"} "mise" "exec" "--" "npm" "ci")
             (sh {:dir "frontend"} "env" "-u" "NO_COLOR" "mise" "exec" "--" "npx" "playwright" "install" "chromium"))}

  playwright:install
  {:doc  "Install Playwright browser binaries"
   :task (sh {:dir "frontend"} "env" "-u" "NO_COLOR" "mise" "exec" "--" "npx" "playwright" "install" "chromium")}

  db:up
  {:doc  "Start a local Postgres container for backend development (no build)"
   :task (sh "docker" "compose" "up" "-d" "--wait" "postgres")}

  db:down
  {:doc  "Stop and remove the local Postgres container"
   :task (do (sh "docker" "compose" "stop" "postgres")
             (sh "docker" "compose" "rm" "-f" "postgres"))}

  up
  {:doc  "Build and start the full stack"
   :task (do (sh "docker" "compose" "up" "-d" "--build" "--wait")
             (println "")
             (println "Stack is up:")
             (println "  http://localhost:4200              Angular app")
             (println "  http://localhost:8080/health       backend health endpoint")
             (println "  http://localhost:8080/openapi.json backend OpenAPI spec")
             (println "  http://localhost:8080/swagger-ui   backend API browser")
             (println ""))}

  down
  {:doc  "Stop the full stack and remove the Postgres data volume"
   :task (sh "docker" "compose" "down" "-v")}

  reset
  {:doc  "Alias for down: stop the stack and remove the Postgres data volume"
   :task (sh "docker" "compose" "down" "-v")}

  clean
  {:doc  "Remove build artefacts"
   :task (sh "rm" "-rf" "backend/target" "backend/.cpcache" "frontend/dist" "frontend/.angular" "frontend/playwright-report" "frontend/test-results")}

  lint:backend
  {:doc  "Lint backend with clj-kondo"
   :task (sh "mise" "exec" "--" "clj-kondo" "--parallel" "--lint" "backend/src:backend/test")}

  lint:frontend
  {:doc  "Lint frontend with ESLint"
   :task (sh {:dir "frontend"} "mise" "exec" "--" "npm" "run" "lint")}

  lint
  {:doc     "Lint backend and frontend"
   :depends [lint:backend lint:frontend]}

  fmt:backend:check
  {:doc  "Check backend formatting with cljfmt"
   :task (sh "mise" "exec" "--" "cljfmt" "check" "backend/src" "backend/test")}

  fmt:frontend:check
  {:doc  "Check frontend formatting with Prettier"
   :task (sh {:dir "frontend"} "mise" "exec" "--" "npm" "run" "format:check")}

  fmt:check
  {:doc     "Check backend and frontend formatting"
   :depends [fmt:backend:check fmt:frontend:check]}

  fmt:backend:fix
  {:doc  "Reformat backend with cljfmt"
   :task (sh "mise" "exec" "--" "cljfmt" "fix" "backend/src" "backend/test")}

  fmt:frontend:fix
  {:doc  "Reformat frontend with Prettier"
   :task (sh {:dir "frontend"} "mise" "exec" "--" "npm" "run" "format")}

  fmt:fix
  {:doc     "Reformat backend and frontend"
   :depends [fmt:backend:fix fmt:frontend:fix]}

  test:backend
  {:doc  "Run backend unit, integration, and adapter tests (adapter tests require Docker)"
   :task (let [docker-host (System/getenv "DOCKER_HOST")
               host-ip     (or (System/getenv "TESTCONTAINERS_HOST_OVERRIDE")
                               (try (str/trim
                                      (:out (clojure.java.shell/sh "rdctl" "info" "--field" "ip-address")))
                                    (catch Exception _ nil)))]
           ; Only forward DOCKER_HOST if already set — otherwise let ~/.testcontainers.properties drive discovery.
           ; TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE tells Testcontainers where to mount the Docker socket
           ; inside helper containers (required for Rancher Desktop, harmless elsewhere).
           (sh {:dir "backend"
                :extra-env (cond-> {"TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE" "/var/run/docker.sock"}
                             docker-host (assoc "DOCKER_HOST" docker-host)
                             host-ip     (assoc "TESTCONTAINERS_HOST_OVERRIDE" host-ip))}
               "clojure" "-M:test"))}

  test:frontend
  {:doc  "Run frontend unit tests with Jest"
   :task (sh {:dir "frontend"} "mise" "exec" "--" "npm" "test")}

  test:acceptance
  {:doc  "Run acceptance tests against the live stack"
   :task (do (require 'acceptance.app-test)
             (let [{:keys [fail error]} (t/run-tests 'acceptance.app-test)]
               (when (pos? (+ fail error))
                 (System/exit 1))))}

  test:e2e
  {:doc  "Run Playwright E2E tests against the live stack"
   :task (do (sh "docker" "compose" "down" "-v")
             (sh "docker" "compose" "up" "-d" "--build" "--wait")
             (try
               (sh {:dir "frontend"} "env" "-u" "NO_COLOR" "mise" "exec" "--" "npx" "playwright" "test")
               (finally
                 (sh "docker" "compose" "down" "-v")
                 (assert-no-running-containers!))))}

  test
  {:doc     "Run all tests"
   :depends [test:backend test:frontend test:acceptance test:e2e]}

  all
  {:doc     "Setup and run all tests end to end"
   :depends [setup test]}}}
